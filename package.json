{
  "name": "void-count-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @void-count/web",
    "build": "npm run build -w @void-count/web",
    "lint": "npm run lint -w @void-count/web",
    "test": "npm run test -w @void-count/core && npm run test -w @void-count/web",
    "test:web": "npm run test -w @void-count/web",
    "test:core": "npm run test -w @void-count/core"
  }
}
